# --- Alpaca API ---
# Get these from https://app.alpaca.markets -> API Keys
ALPACA_API_KEY=PKAE2LI6BH6N6TWG3IX6C5NYQPPKAE2LI6BH6N6TWG3IX6C5NYQP
ALPACA_SECRET_KEY=E5NdrApDU4gyfaPS7qrqDNUopoEmmZP7djYqDoYFiBzY
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading URL
# ALPACA_BASE_URL=https://api.alpaca.markets        # live trading URL (future)

# --- Groq (free tier) ---
# Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Application Settings ---
ENVIRONMENT=development        # development | paper | live
LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR
DATABASE_URL=sqlite:///data/trading.db

# --- Risk Parameters ---
MAX_RISK_PER_TRADE_PCT=0.02    # 2% max risk per trade
DAILY_LOSS_LIMIT_PCT=0.03      # 3% daily loss limit
MAX_PORTFOLIO_EXPOSURE_PCT=0.80 # Max 80% of portfolio deployed

# --- Trading Universe ---
WATCHLIST=["AAPL","MSFT","GOOGL","AMZN","NVDA","SPY","QQQ"]
